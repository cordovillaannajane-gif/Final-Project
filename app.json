{
  "expo": {
    "name": "TaskList",
    "slug": "TaskList",
    "version": "1.0.0",
    "orientation": "portrait",
    
    "scheme": "tasklist",
    "userInterfaceStyle": "automatic",


    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
  
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "bundler": "metro"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}